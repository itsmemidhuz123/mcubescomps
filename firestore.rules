rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // -------------------------------------------------------------------------
    // HELPER FUNCTIONS
    // -------------------------------------------------------------------------
    
    // Check if user is authenticated
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Check if user is admin
    // Matches 'ADMIN' (used in AuthContext.js) or 'admin' (legacy/manual)
    // Ensures access if either format is used in the user document
    function isAdmin() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             (
               get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'ADMIN' || 
               get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
             );
    }
    
    // Check if user owns the document being accessed
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // -------------------------------------------------------------------------
    // COLLECTION RULES
    // -------------------------------------------------------------------------
    
    // Users collection
    match /users/{userId} {
      // Allow public read for profiles/leaderboards
      allow read: if true;
      
      // Creation: User can create their own profile
      allow create: if isSignedIn() && request.auth.uid == userId;
      
      // Update: User can update own profile, Admin can update any
      allow update: if isOwner(userId) || isAdmin();
      
      // Delete: Only Admin
      allow delete: if isAdmin();
    }
    
    // Competitions collection
    match /competitions/{competitionId} {
      // Public read
      allow read: if true;
      
      // Admin only write access
      allow create, update, delete: if isAdmin();
    }
    
    // Results collection
    match /results/{resultId} {
      // Public read
      allow read: if true;
      
      // Create: User can create result if it belongs to them
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      
      // Update/Delete: Owner or Admin
      allow update, delete: if isSignedIn() && 
                           (resource.data.userId == request.auth.uid || isAdmin());
    }
    
    // Registrations collection
    match /registrations/{registrationId} {
      // Public read (for participant counts)
      allow read: if true;
      
      // Create: User can register themselves
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      
      // Update: Owner or Admin
      allow update: if isSignedIn() && 
                   (resource.data.userId == request.auth.uid || isAdmin());
      
      // Delete: Only Admin
      allow delete: if isAdmin();
    }

    // Solves collection
    // Contains competition attempt data; only owner can read, only owner can create.
    // Updates are restricted to admins to prevent tampering after submission.
    match /solves/{solveId} {
      // Admin can read all (for flagged solves review), users can read their own
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // Scramble reveal tracking
    // Used to mark attempts as revealed/submitted; only owner can read/write their reveal docs.
    match /scrambleReveals/{revealId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && (
        isAdmin() || (
          resource.data.userId == request.auth.uid &&
          request.resource.data.userId == resource.data.userId
        )
      );
      allow delete: if isAdmin();
    }
    
    // Payments collection
    // IMPORTANT: This contains sensitive financial data
    match /payments/{paymentId} {
      // Read: Owner can see own payments, Admin can see ALL
      // Note: Admin can query collectionGroup, User must query with where('userId', '==', auth.uid)
      allow read: if isSignedIn() && 
                 (resource.data.userId == request.auth.uid || isAdmin());
      
      // Create: Authenticated users (for checkout)
      allow create: if isSignedIn();
      
      // Update: Admin only (for status updates/refunds)
      allow update: if isAdmin();
      
      // Delete: No one (Immutable)
      allow delete: if false;
    }
    
    // Anti-cheat logs
    match /antiCheatLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }
    
    // Audit logs (Admin actions)
    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }
    
    match /coupons/{couponId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }
    
    match /couponUsages/{usageId} {
      allow read: if isAdmin();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }
    
    // Tournament Participants
    // Tracks user progress through tournament rounds
    match /tournamentParticipants/{participantId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow delete: if isAdmin();
    }
    
    // Round Results
    // Stores results for each round of a tournament
    match /roundResults/{resultId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }
    
    // Tournament advancement logs
    match /tournamentLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }
    
    // Video Submissions
    match /videoSubmissions/{submissionId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
