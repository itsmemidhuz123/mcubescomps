rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Helper function to check if user is admin
    function isAdmin() {
      return isSignedIn() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // Helper function to check if user owns the document
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    // Users collection
    match /users/{userId} {
      // Anyone can read public user profiles (for leaderboards, public profiles)
      allow read: if true;
      
      // Users can create their own profile during registration
      allow create: if isSignedIn() && request.auth.uid == userId;
      
      // Users can update their own profile, admins can update any profile
      allow update: if isOwner(userId) || isAdmin();
      
      // Only admins can delete users
      allow delete: if isAdmin();
    }
    
    // Competitions collection
    match /competitions/{competitionId} {
      // Anyone can read competitions (for browsing, leaderboards)
      allow read: if true;
      
      // Only admins can create, update, or delete competitions
      allow create, update, delete: if isAdmin();
    }
    
    // Results collection (TOP-LEVEL COLLECTION - not subcollection)
    match /results/{resultId} {
      // Anyone can read results (for public leaderboards, rankings, profiles)
      allow read: if true;
      
      // Users can create their own results during competition
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      
      // Users can update their own results, admins can update any
      allow update: if isSignedIn() && 
                       (resource.data.userId == request.auth.uid || isAdmin());
      
      // Users can delete their own results, admins can delete any
      allow delete: if isSignedIn() && 
                       (resource.data.userId == request.auth.uid || isAdmin());
    }
    
    // Registrations collection
    match /registrations/{registrationId} {
      // Anyone can read registrations (needed for leaderboard participant count)
      allow read: if true;
      
      // Users can create their own registrations
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      
      // Users can update their own registrations, admins can update any
      allow update: if isSignedIn() && 
                       (resource.data.userId == request.auth.uid || isAdmin());
      
      // Only admins can delete registrations
      allow delete: if isAdmin();
    }
    
    // Payments collection (for tracking payment history)
    match /payments/{paymentId} {
      // Users can read their own payments, admins can read all
      allow read: if isSignedIn() && 
                     (resource.data.userId == request.auth.uid || isAdmin());
      
      // Only server (admin) can create payment records
      allow create: if isAdmin();
      
      // No one can update or delete payment records (immutable audit trail)
      allow update, delete: if false;
    }
    
    // Anti-cheat logs collection
    match /antiCheatLogs/{logId} {
      // Only admins can read anti-cheat logs
      allow read: if isAdmin();
      
      // System can create logs (via server-side)
      allow create: if isSignedIn();
      
      // No one can update or delete logs (immutable audit trail)
      allow update, delete: if false;
    }
    
    // Audit logs collection (for admin actions)
    match /auditLogs/{logId} {
      // Only admins can read audit logs
      allow read: if isAdmin();
      
      // System can create logs
      allow create: if isAdmin();
      
      // No one can update or delete logs (immutable audit trail)
      allow update, delete: if false;
    }
    
    // Block all other collections by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}