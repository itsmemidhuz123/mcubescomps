rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================
    // MCUBES SPEEDCUBING PLATFORM RULES
    // ============================================
    
    // Users collection - public read, owner write
    match /users/{userId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;
    }
    
    // Competitions - public read, admin write (for now allow authenticated)
    match /competitions/{competitionId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Results - public read for leaderboards
    match /results/{resultId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }
    
    // Registrations - authenticated users
    match /registrations/{registrationId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }
    
    // Solves - authenticated users can write, public can read
    match /solves/{solveId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }
    
    // Scramble reveals - for tracking DNF on refresh
    match /scrambleReveals/{revealId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    
    // Payments - PRIVATE: only owner and admin can see
    // Users can only see their own payments
    match /payments/{paymentId} {
      // Allow read if user is authenticated and either:
      // 1. They own this payment (userId matches)
      // 2. They are the admin
      allow read: if request.auth != null && 
        (resource.data.userId == request.auth.uid || 
         request.auth.token.email == 'midhun.speedcuber@gmail.com');
      allow create: if request.auth != null;
      allow update, delete: if false;
    }
  }
}
