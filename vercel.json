{
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "X-Content-Type-Options",
                    "value": "nosniff"
                },
                {
                    "key": "Content-Security-Policy",
                    "value": "frame-ancestors 'self' https://alpha.twizzle.net https://twizzle.net https://cubing.net https://cdn.cubing.net;"
                }
            ]
        }
    ],
    "cleanUrls": true,
    "trailingSlash": false
}